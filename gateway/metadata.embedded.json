{
  "name": "mesh_gateway",
  "version": "0.3.3",
  "type": "core",
  "category": "network",
  "description": "Mesh gateway — bridge a connected LoRa mesh node (Meshtastic or MeshCore) to/from Logos Messaging",
  "main": "mesh_gateway_plugin",
  "dependencies": ["delivery_module"],
  "events": ["channelsChanged", "nodeStatus", "messagesChanged"],
  "nix": {
    "packages": {
      "build": ["protobuf", "qt6.qtserialport", "qt6.qtbase", "openssl"],
      "runtime": ["protobuf", "qt6.qtserialport", "qt6.qtbase", "openssl"]
    },
    "external_libraries": [],
    "cmake": {}
  }
}
